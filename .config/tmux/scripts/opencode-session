#!/bin/bash
PANE_PATH="$1"
cd "$PANE_PATH" || exit 1

if ROOT=$(git rev-parse --show-toplevel 2>/dev/null); then
  PROJECT_NAME=$(basename "$ROOT")
  WORK_DIR="$ROOT"
else
  PROJECT_NAME=$(basename "$PANE_PATH")
  WORK_DIR="$PANE_PATH"
fi

SESSION="opencode-$PROJECT_NAME-$(echo "$WORK_DIR" | md5sum | cut -c1-8)"

tmux has-session -t "$SESSION" 2>/dev/null || \
  tmux new-session -d -s "$SESSION" -c "$WORK_DIR" "opencode"

tmux display-popup -w80% -h80% -E "tmux attach-session -t $SESSION"
